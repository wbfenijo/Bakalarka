@startuml
actor "Drone Commander" as DC
actor "Semi-autonomous UAV" as UAV
participant "DroneResponse" as DR

DC -> DR : Activate search
DR -> UAV : Place in launch positions
UAV -> UAV : Activate and arm
DR -> DR : Generate flight routes
DR -> UAV : Issue command to start mission
UAV -> UAV : Perform synchronized takeoff
UAV -> UAV : Fly assigned flight routes
UAV -> UAV : Perform image capture and analysis
UAV -> UAV : Detect potential victim
UAV -> DR : Raise victim_detection event
DR -> DR : Forward event to UIs
UAV -> UAV : Switch to active tracking mode
DR -> UAV : Request victim confirmation
UAV -> DC : Confirm victim sighting
DR -> DR : Send GPS coordinates to mobile_rescue
UAV -> UAV : Deliver flotation device
DC -> DC : End the mission

alt Manual delivery of flotation device
    UAV -> Responders : Confirm manual delivery
end

alt Low confidence victim detection
    UAV -> UAV : Raise notification with imagery
    DR -> DR : Save GPS coordinates
    UAV -> UAV : Continue assigned route
    DC -> DC : Review imagery
    DC -> UAV : Confirm not a victim
end

alt Refuted sighting
    DR -> UAV : Resume search activity
end

alt No tracking permission
    UAV -> UAV : Continue search
    DC -> UAV : Confirm victim sighting
    UAV -> UAV : Attempt to relocate and track
end

@enduml