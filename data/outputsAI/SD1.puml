```plantuml
@startuml
actor "Drone Commander" as Commander
actor "Semi-autonomous UAV" as UAV
participant "DroneResponse" as Response
participant "Mobile Rescue System" as Rescue
participant "Human Operator" as Operator
participant "Emergency Responders" as Responders

Commander -> Response : Activate the search
Response -> UAV : Place in launch positions
Response -> UAV : Activate and arm
Responders -> Response : Initiate dynamic flight routes
Response -> UAV : Start the mission
UAV -> UAV : Perform synchronized takeoff
UAV -> UAV : Lease airspace and fly assigned routes
UAV -> UAV : Perform image capture and analysis
UAV -> UAV : Detect potential victim
UAV -> Response : Raise victim_detection event
Response -> Operator : Forward victim_detection alert
Operator -> UAV : Confirm victim sighting
UAV -> Response : Request victim confirmation
UAV -> Rescue : Send GPS coordinates
UAV -> Rescue : Deliver flotation device
Responders -> Rescue : Arrive at the scene
Commander -> Response : End the mission

alt Human responders deliver manually
    Responders -> Rescue : Deliver flotation device manually
end

opt UAV detects possible victim but low confidence
    UAV -> Response : Raise notification with imagery
    Response -> Response : Save GPS coordinates
    UAV -> UAV : Continue assigned route
    Operator -> UAV : Review streamed imagery
    Operator -> UAV : Confirm not a victim
end

opt Operator refutes sighting validity
    UAV -> Response : Resume previous search activity
end

opt UAV needs permission for tracking
    UAV -> UAV : Continue search without tracking
    Operator -> UAV : If confirmed, relocate victim
end
@enduml
```