@startuml
actor DroneCommander
actor SeamlessUAV
boundary DroneResponse
boundary MobileRescueSystem
boundary HumanOperator

DroneCommander -> DroneResponse : activate search
DroneResponse -> SeamlessUAV : place in launch positions
SeamlessUAV -> SeamlessUAV : activate and arm
DroneResponse -> EmergencyResponders : generate flight routes
DroneResponse -> SeamlessUAV : start mission
SeamlessUAV -> SeamlessUAV : synchronized takeoff
SeamlessUAV -> SeamlessUAV : lease airspace and fly routes
SeamlessUAV -> SeamlessUAV : perform image capture and analysis
SeamlessUAV -> SeamlessUAV : detect potential victim
alt victim detected at threshold
    SeamlessUAV -> DroneResponse : raise victim_detection event
    DroneResponse -> HumanOperator : forward event
    SeamlessUAV -> SeamlessUAV : switch to active tracking mode
    DroneResponse -> HumanOperator : request victim confirmation
    HumanOperator -> SeamlessUAV : confirm victim sighting
    DroneResponse -> MobileRescueSystem : send GPS coordinates
    SeamlessUAV -> MobileRescueSystem : deliver flotation device
    HumanResponder -> HumanResponder : arrive at the scene
else low confidence detection
    SeamlessUAV -> SeamlessUAV : raise notification with imagery
    DroneResponse -> SeamlessUAV : save GPS coordinates
    SeamlessUAV -> SeamlessUAV : continue assigned route
    BackUpOperator -> SeamlessUAV : review imagery
    BackUpOperator -> SeamlessUAV : confirm no victim
end
alt human refutes validity
    HumanOperator -> SeamlessUAV : refute sighting
    SeamlessUAV -> SeamlessUAV : resume previous search
end
alt no permission for tracking
    SeamlessUAV -> SeamlessUAV : continue search without tracking
    HumanOperator -> SeamlessUAV : confirm victim sighting
    SeamlessUAV -> SeamlessUAV : relocate and start tracking
end
DroneCommander -> DroneResponse : end mission
@enduml