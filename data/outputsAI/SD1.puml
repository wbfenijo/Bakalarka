@startuml
actor DroneCommander
actor UAV

DroneCommander -> UAV : Place in launch positions
UAV -> UAV : Activate and arm
UAV -> UAV : Initiate dynamic generation of flight routes
DroneCommander -> UAV : Issue command to start mission
UAV -> UAV : Perform synchronized takeoff
UAV -> UAV : Lease airspace and fly assigned routes
UAV -> UAV : Perform image capture and analysis
UAV -> UAV : Detect potential victim (confidence level above threshold)
UAV -> DroneCommander : Raise victim_detection event
DroneCommander -> UAV : Forward event to all UIs
UAV -> UAV : Switch to active tracking mode
UAV -> DroneCommander : Request victim confirmation
DroneCommander -> UAV : Confirm victim sighting
UAV -> DroneCommander : Send GPS coordinates to mobile_rescue
UAV -> UAV : Deliver flotation device
UAV -> DroneCommander : Human responders arrive at scene
DroneCommander -> UAV : End mission

alt Human responders deliver manually
    UAV -> DroneCommander : Human responders deliver flotation device manually
end

alt Confidence level below threshold
    UAV -> UAV : Raise notification with imagery
    UAV -> UAV : Save GPS coordinates of sighting
    UAV -> UAV : Continue assigned route
    UAV -> UAV : Back-up operator reviews imagery
    UAV -> UAV : Back-up operator confirms no victim
end

alt Human operator refutes sighting
    UAV -> UAV : Resume previous search activity
end

alt No permission for automatic tracking
    UAV -> UAV : Continue search without tracking
    UAV -> UAV : Attempt to relocate and start tracking if confirmed
end
@enduml